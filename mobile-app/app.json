{
  "expo": {
    "name": "CareLink",
    "slug": "carelink-mobile-app",
    "scheme": "ma.carelink.app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ma.carelink.app"
    },
    "android": {
      "package": "ma.carelink.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-location",
      "expo-web-browser",
      "expo-image-picker",
      "expo-dev-client",
      "expo-notifications",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2375654a-8457-4b53-863d-f5b3b2607e0e"
      }
    },
    "owner": "walidzakan"
  }
}
