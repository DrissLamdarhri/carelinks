{
  "expo": {
    "name": "CareLink",
    "slug": "carelink-mobile-app",
    "scheme": "ma.carelink.app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D0870"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ma.carelink.app"
    },
    "android": {
      "package": "ma.carelink.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
