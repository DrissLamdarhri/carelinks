{
  "name": "@carelink/mobile-app",
  "version": "1.0.0",
  "description": "CareLink React Native mobile app - mirrors web architecture",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "set \"REACT_NATIVE_PACKAGER_HOSTNAME=192.168.11.104\" && set \"EXPO_NO_DEPENDENCY_VALIDATION=true\" && expo start --clear --host lan",
    "start:online": "set \"REACT_NATIVE_PACKAGER_HOSTNAME=192.168.11.104\" && set \"EXPO_NO_DEPENDENCY_VALIDATION=true\" && expo start --host lan",
    "start:usb": "set \"REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1\" && set \"EXPO_NO_DEPENDENCY_VALIDATION=true\" && expo start --clear --host localhost",
    "android": "set \"REACT_NATIVE_PACKAGER_HOSTNAME=192.168.11.104\" && set \"EXPO_NO_DEPENDENCY_VALIDATION=true\" && expo start --android --host lan",
    "ios": "set \"REACT_NATIVE_PACKAGER_HOSTNAME=192.168.11.104\" && set \"EXPO_NO_DEPENDENCY_VALIDATION=true\" && expo start --ios --host lan",
    "web": "set \"EXPO_NO_DEPENDENCY_VALIDATION=true\" && expo start --web",
    "tunnel:fallback": "node ./scripts/start-tunnel-fallback.js",
    "build": "eas build",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/dm-serif-display": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.2.0",
    "@react-native/metro-config": "^0.85.2",
    "@supabase/supabase-js": "^2.43.0",
    "axios": "^1.6.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "expo": "^56.0.12",
    "expo-auth-session": "^56.0.14",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "^56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-image-picker": "^57.0.1",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "^56.0.14",
    "expo-location": "~56.0.18",
    "expo-notifications": "^56.0.18",
    "expo-router": "^56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "^56.0.10",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.14.0",
    "nativewind": "^4.2.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-css-interop": "0.2.4",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-react-display-name": "^7.28.0",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/plugin-transform-react-jsx-development": "^7.27.1",
    "@babel/plugin-transform-react-pure-annotations": "^7.27.1",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^8.55.0",
    "react-native-worklets-core": "^1.6.3",
    "typescript": "~6.0.3"
  }
}
